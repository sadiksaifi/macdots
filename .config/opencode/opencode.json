{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ask",
  "autoupdate": false,
  "permission": {
    "*": "allow"
  },
  "provider": {
    "lmstudio-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio Local",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "local"
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "GPT-OSS 20B",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    }
  }
}
