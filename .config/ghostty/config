font-family = "JetBrainsMono Nerd Font"
font-size = 20
theme = Vague
shell-integration-features = no-cursor,sudo,no-title
background-opacity = 0.93
# background-opacity = 1
background-blur = 100

unfocused-split-opacity = 1

window-padding-balance = true 
window-save-state = always
macos-titlebar-style = hidden
# macos-titlebar-style = tabs #transparent, tabs, native, hidden
window-decoration = none
# macos-window-shadow = false
window-colorspace = "display-p3"
confirm-close-surface = true
background=#141415
# background=#14161b
# background = #1E1E1E
# background = #000000
# background = #242424

# # keybindings
# keybind = ctrl+b>x=close_surface
# keybind = ctrl+b>n=new_window
# 
# # tabs 
# keybind = ctrl+b>c=new_tab
# keybind = ctrl+b>n=next_tab
# keybind = ctrl+b>p=previous_tab
# 
# # split
# keybind = ctrl+b>shift+5=new_split:right
# keybind = ctrl+b>shift+'=new_split:down
# 
# keybind = ctrl+b>j=goto_split:bottom
# keybind = ctrl+b>k=goto_split:top
# keybind = ctrl+b>h=goto_split:left
# keybind = ctrl+b>l=goto_split:right
# 
# keybind = ctrl+b>z=toggle_split_zoom
# 
# keybind = ctrl+b>e=equalize_splits

# other
copy-on-select = clipboard

# Keybinds
keybind = alt+backspace=text:\x1b\x7f
keybind = shift+enter=text:\x1b\r

# Unbind Ghostty's default Cmd+N tab switching
keybind = super+one=unbind
keybind = super+digit_1=unbind
keybind = super+two=unbind
keybind = super+digit_2=unbind
keybind = super+three=unbind
keybind = super+digit_3=unbind
keybind = super+four=unbind
keybind = super+digit_4=unbind
keybind = super+five=unbind
keybind = super+digit_5=unbind
keybind = super+six=unbind
keybind = super+digit_6=unbind
keybind = super+seven=unbind
keybind = super+digit_7=unbind
keybind = super+eight=unbind
keybind = super+digit_8=unbind
keybind = super+nine=unbind
keybind = super+digit_9=unbind

# Cmd+N → tmux prefix (Ctrl+B) + N to switch windows
keybind = super+one=text:\x021
keybind = super+two=text:\x022
keybind = super+three=text:\x023
keybind = super+four=text:\x024
keybind = super+five=text:\x025
keybind = super+six=text:\x026
keybind = super+seven=text:\x027
keybind = super+eight=text:\x028
keybind = super+nine=text:\x029
