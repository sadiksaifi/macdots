{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "true"
  },
  "includeCoAuthoredBy": false,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ClaudeNotify.app/Contents/MacOS/notify task-done"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ClaudeNotify.app/Contents/MacOS/notify task-failed"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ClaudeNotify.app/Contents/MacOS/notify permission"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ClaudeNotify.app/Contents/MacOS/notify idle"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ClaudeNotify.app/Contents/MacOS/notify elicitation"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/statusline"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "greptile@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "mcp__*",
      "Skill",
      "Bash(bun run typecheck*)",
      "Bash(bun run tsc*)",
      "Bash(bun run lint*)",
      "Bash(bun run format*)",
      "Bash(bun run fmt*)",
      "Bash(bunx tsc*)",
      "Bash(bunx eslint*)",
      "Bash(bunx prettier*)",
      "Bash(bunx biome*)",
      "Bash(pnpm run typecheck*)",
      "Bash(pnpm run tsc*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm run format*)",
      "Bash(pnpm run fmt*)",
      "Bash(pnpm exec tsc*)",
      "Bash(pnpm exec eslint*)",
      "Bash(pnpm exec prettier*)",
      "Bash(pnpm exec biome*)",
      "Read",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git tag*)",
      "Bash(git stash list*)",
      "Bash(git remote -v*)",
      "Bash(git blame*)",
      "Bash(git shortlog*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git ls-remote*)",
      "Bash(git describe*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)"
    ]
  }
}
